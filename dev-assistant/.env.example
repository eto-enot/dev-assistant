API_BASE_URL=http://localhost:4000/v1               # Адрес шлюза LiteLLM
QDRANT_URL=http://localhost                         # Адрес сервиса Qdrant
PROXY_URL=http://localhost:8888                     # Адрес прокси-сервера (не обязательно)
REDIS_URL=redis://localhost:6379/0                  # Строка подключения к Redis (для Celery)
OTEL_SERVICE_NAME=dev-assistant                     # Название сервиса ассистента (для сервисов observability)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317   # Адрес OpenTelemetry Collector
OTEL_EXPORTER_OTLP_PROTOCOL=grpc                    # Протокол взаимодействия с OpenTelemetry Collector
RAG_TOP_K=10                                        # Количество отбираемых элементов при поиске RAG
RAG_CHUNK_SIZE=256                                  # Размер фрагмента при индексировании